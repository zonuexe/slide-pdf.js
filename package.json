{
  "name": "slide-pdf.js",
  "description": "pdf slide on the web.",
  "version": "1.0.0",
  "homepage": "https://github.com/zonuexe/slide-pdf.js/",
  "repository": {
    "type": "git",
    "url": "https://github.com/zonuexe/slide-pdf.js.git"
  },
  "main": "index.js",
  "scripts": {
    "bundle": "esbuild src/main.ts --bundle --format=esm --platform=browser --target=es2020 --external:pdfjs-dist --external:pdfjs-dist/* --sourcemap --outfile=app.js",
    "build": "npm run bundle && node scripts/copy-assets.js",
    "watch": "esbuild src/main.ts --bundle --format=esm --platform=browser --target=es2020 --external:pdfjs-dist --external:pdfjs-dist/* --sourcemap --outfile=app.js --watch",
    "start": "npm run build && static-server",
    "test": "echo \"No automated tests defined\""
  },
  "directories": {
    "test": "test/"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "azu",
  "maintainers": [
    {
      "name": "zonuexe",
      "email": "tadsan@zonu.me",
      "url": "https://github.com/zonuexe"
    }
  ],
  "contributors": [
    { "name": "azu" },
    { "name": "zonuexe" }
  ],
  "license": "GPL-2.0-or-later",
  "bugs": {
    "url": "https://github.com/zonuexe/slide-pdf.js/issues"
  },
  "dependencies": {
    "@zonuexe/pdf.js-controller": "^2.0.0",
    "es-toolkit": "^1.47.1",
    "pdfjs-dist": "^6.0.227"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "static-server": "^3.0.0"
  }
}
